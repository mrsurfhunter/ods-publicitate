# ── Runtime (server.js) ──────────────────────────────────────
# Cheie API Anthropic — necesara pentru functia AI
ANTHROPIC_API_KEY=sk-ant-...

# Cheie API OpenAI — generare bannere AI (GPT Image)
OPENAI_API_KEY=sk-...

# Cheie API firmeapi.ro — lookup CUI
FIRMEAPI_KEY=

# WordPress credentials (server-side only, NOT exposed to frontend)
WP_URL=https://www.oradesibiu.ro
WP_USER=
WP_PASS=

# Parola admin panel (accesibil la #admin)
ADMIN_PASSWORD=

# ── Stripe (plata cu cardul) ─────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
# URL-ul aplicatiei (pentru redirect dupa plata)
APP_URL=https://publicitate.oradesibiu.ro

# ── Notificari comenzi ───────────────────────────────────────
# Email SMTP — notificare admin la comanda noua
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=email@oradesibiu.ro
SMTP_PASS=
SMTP_FROM=Publicitate ODS <publicitate@oradesibiu.ro>
NOTIFY_EMAIL=redactie@oradesibiu.ro

# Webhook URL (n8n, Zapier, etc.) — optional
NOTIFY_WEBHOOK=https://agent.ora.red/webhook/new-order

# Port server (default 3001)
PORT=3001

# ── Build-time (embedded in bundle Vite) ─────────────────────
# URL site WordPress (public, only used for display)
VITE_WP_URL=https://www.oradesibiu.ro
