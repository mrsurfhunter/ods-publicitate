# ── Runtime (server.js) ──────────────────────────────────────
# Cheie API Anthropic — necesara pentru functia AI
ANTHROPIC_API_KEY=sk-ant-...

# Cheie API OpenAI — generare bannere AI (GPT Image)
OPENAI_API_KEY=sk-...

# Cheie API firmeapi.ro — lookup CUI
FIRMEAPI_KEY=

# WordPress credentials (server-side only, NOT exposed to frontend)
WP_URL=https://www.oradesibiu.ro
WP_USER=
WP_PASS=

# Parola admin panel (accesibil la #admin)
ADMIN_PASSWORD=

# ── Twilio Verify (OTP SMS pentru autentificare prin telefon) ─
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_VERIFY_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Stripe (plata cu cardul) ─────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
# URL-ul aplicatiei (pentru redirect dupa plata)
APP_URL=https://publicitate.oradesibiu.ro

# ── Notificari comenzi ───────────────────────────────────────
# Email SMTP — notificare admin la comanda noua
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=email@oradesibiu.ro
SMTP_PASS=
SMTP_FROM=Publicitate ODS <publicitate@oradesibiu.ro>
NOTIFY_EMAIL=redactie@oradesibiu.ro

# Date bancare (afisate in emailul de proforma catre client)
BANK_IBAN=RO00XXXX0000000000000000
BANK_NAME=Banca Transilvania

# Webhook URL (n8n, Zapier, etc.) — optional
NOTIFY_WEBHOOK=https://agent.ora.red/webhook/new-order

# ── FGO Facturare ────────────────────────────────────────────
# CUI-ul companiei emitente
FGO_CUI=39899930
# Cheie privata API (din Setari > Utilizatori > Genereaza utilizator API)
FGO_PRIVATE_KEY=770A3F705A4C0471E82B768ED3E780F8
# Seria de facturare (din Setari > Serii Documente in FGO)
FGO_SERIE=OSB
# URL API (production default, test: https://api-testuat.fgo.ro/v1)
FGO_API_URL=https://api.fgo.ro/v1

# Port server (default 3001)
PORT=3001

# ── Build-time (embedded in bundle Vite) ─────────────────────
# URL site WordPress (public, only used for display)
VITE_WP_URL=https://www.oradesibiu.ro
