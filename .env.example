# ── Runtime (server.js) ──────────────────────────────────────
# Cheie API Anthropic — necesara pentru functia "Imbunatateste cu AI"
ANTHROPIC_API_KEY=sk-ant-...

# Port server (default 3001)
PORT=3001

# ── Build-time (embedded in bundle Vite) ─────────────────────
# URL site WordPress
VITE_WP_URL=https://www.oradesibiu.ro

# WordPress Application Password (Settings > Users > Application Passwords)
# Format: username:xxxx xxxx xxxx xxxx xxxx xxxx
VITE_WP_USER=
VITE_WP_PASS=
