# ── Runtime (server.js) ──────────────────────────────────────
# Cheie API Anthropic — necesara pentru AI
ANTHROPIC_API_KEY=sk-ant-...

# Model AI (optional, default: claude-sonnet-4-20250514)
# AI_MODEL=claude-sonnet-4-20250514

# Port server (default 3001)
PORT=3001

# ── WordPress (server-side, NOT embedded in frontend) ────────
# URL site WordPress
WP_URL=https://www.oradesibiu.ro

# WordPress Application Password (Settings > Users > Application Passwords)
WP_USER=username
WP_PASS=xxxx xxxx xxxx xxxx xxxx xxxx

# ── CUI Lookup (firmeapi.ro) ─────────────────────────────────
FIRMEAPI_KEY=your-api-key

# ── CORS (optional) ──────────────────────────────────────────
# CORS_ORIGIN=https://publicitate.oradesibiu.ro
